class SerialComms:

    def __init__(self):
        self.__port = serial.Serial(
            port="/dev/ttyUSB0",
            baudrate=9600,
            timeout=1
        )

    def isOpen(self):
        return self.__port.is_open

    def readPort(self):
        return self.__port.readline()   # RAW BYTES

    def writePort(self, data):
        self.__port.write(data)


