class HASP_STATES:

    def __init__(self):
        self.current_state = "INIT"

    def transition(self, state):
        if state in ["INTEGRATION","INIT", "RUNNING"]:
            self.current_state = state
            return self.current_state
        else:
            print(f"Invalid State {state}")

